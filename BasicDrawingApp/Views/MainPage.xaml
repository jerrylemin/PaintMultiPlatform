<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BasicDrawingApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:BasicDrawingApp.Controls"
    xmlns:models="clr-namespace:BasicDrawingApp.Models"
    xmlns:vm="clr-namespace:BasicDrawingApp.ViewModels"
    x:DataType="vm:MainViewModel"
    Title="Basic Drawing App"
    BackgroundColor="#E9EEF3">

    <Grid Padding="12" RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <Border Grid.Row="0" Padding="12" BackgroundColor="#FFFFFF" Stroke="#CBD5E1" StrokeThickness="1">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                <Label FontAttributes="Bold" FontSize="20" Text="Basic Drawing App" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="{Binding StatusMessage}" TextColor="#334155" LineBreakMode="TailTruncation" VerticalOptions="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="10" BackgroundColor="#FFFFFF" Stroke="#CBD5E1" StrokeThickness="1">
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always">
                <HorizontalStackLayout Spacing="14">
                    <VerticalStackLayout WidthRequest="440" Spacing="8">
                        <Label FontAttributes="Bold" Text="Tools" />
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Text="Point" BackgroundColor="{Binding PointToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Point}" />
                            <Button Grid.Column="1" Text="Line" BackgroundColor="{Binding LineToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Line}" />
                            <Button Grid.Column="2" Text="Rectangle" BackgroundColor="{Binding RectangleToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Rectangle}" />
                            <Button Grid.Row="1" Text="Square" BackgroundColor="{Binding SquareToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Square}" />
                            <Button Grid.Row="1" Grid.Column="1" Text="Ellipse" BackgroundColor="{Binding EllipseToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Ellipse}" />
                            <Button Grid.Row="1" Grid.Column="2" Text="Circle" BackgroundColor="{Binding CircleToolBackground}" TextColor="White" Command="{Binding SelectToolCommand}" CommandParameter="{x:Static models:ShapeKind.Circle}" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout WidthRequest="360" Spacing="8">
                        <Label FontAttributes="Bold" Text="{Binding StrokeColorName, StringFormat='Stroke: {0}'}" />
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Text="Black" BackgroundColor="#111827" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Black" />
                            <Button Grid.Column="1" Text="Red" BackgroundColor="#DC2626" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Red" />
                            <Button Grid.Column="2" Text="Green" BackgroundColor="#16A34A" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Green" />
                            <Button Grid.Column="3" Text="Blue" BackgroundColor="#2563EB" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Blue" />
                            <Button Grid.Row="1" Text="Yellow" BackgroundColor="#CA8A04" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Yellow" />
                            <Button Grid.Row="1" Grid.Column="1" Text="Purple" BackgroundColor="#7C3AED" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Purple" />
                            <Button Grid.Row="1" Grid.Column="2" Text="Orange" BackgroundColor="#EA580C" TextColor="White" Command="{Binding SelectStrokeColorCommand}" CommandParameter="Orange" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout WidthRequest="440" Spacing="8">
                        <Label FontAttributes="Bold" Text="{Binding FillColorName, StringFormat='Fill: {0}'}" />
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Text="Transparent" BackgroundColor="#64748B" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Transparent" />
                            <Button Grid.Column="1" Text="Black" BackgroundColor="#111827" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Black" />
                            <Button Grid.Column="2" Text="Red" BackgroundColor="#DC2626" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Red" />
                            <Button Grid.Column="3" Text="Green" BackgroundColor="#16A34A" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Green" />
                            <Button Grid.Row="1" Text="Blue" BackgroundColor="#2563EB" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Blue" />
                            <Button Grid.Row="1" Grid.Column="1" Text="Yellow" BackgroundColor="#CA8A04" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Yellow" />
                            <Button Grid.Row="1" Grid.Column="2" Text="Purple" BackgroundColor="#7C3AED" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Purple" />
                            <Button Grid.Row="1" Grid.Column="3" Text="Orange" BackgroundColor="#EA580C" TextColor="White" Command="{Binding SelectFillColorCommand}" CommandParameter="Orange" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout WidthRequest="300" Spacing="8">
                        <Label FontAttributes="Bold" Text="Options" />
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <CheckBox IsChecked="{Binding IsFillEnabled}" />
                            <Label Text="Enable Fill" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label FontAttributes="Bold" Text="{Binding StrokeThicknessText, StringFormat='Thickness: {0}'}" />
                        <Slider Minimum="1" Maximum="20" Value="{Binding StrokeThickness}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout WidthRequest="460" Spacing="8">
                        <Label FontAttributes="Bold" Text="Actions" />
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Text="Undo" Command="{Binding UndoCommand}" />
                            <Button Grid.Column="1" Text="Redo" Command="{Binding RedoCommand}" />
                            <Button Grid.Column="2" Text="Clear" Command="{Binding ClearCommand}" />
                            <Button Grid.Column="3" Text="Save .bdraw" Command="{Binding SaveCommand}" />
                            <Button Grid.Row="1" Text="Load .bdraw" Command="{Binding LoadCommand}" />
                            <Button Grid.Row="1" Grid.Column="1" Text="Export PNG" Command="{Binding ExportPngCommand}" />
                            <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="Export JPEG" Command="{Binding ExportJpegCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Row="2" Padding="2" BackgroundColor="#FFFFFF" Stroke="#0F172A" StrokeThickness="2">
            <controls:DrawingCanvasView
                AddShapeCommand="{Binding AddShapeCommand}"
                Document="{Binding Document}"
                IsFillEnabled="{Binding IsFillEnabled}"
                MinimumHeightRequest="420"
                PreviewShape="{Binding PreviewShape, Mode=TwoWay}"
                SelectedFillColor="{Binding SelectedFillColor}"
                SelectedStrokeColor="{Binding SelectedStrokeColor}"
                SelectedTool="{Binding SelectedTool}"
                Shapes="{Binding Shapes}"
                StrokeThickness="{Binding StrokeThickness}" />
        </Border>
    </Grid>
</ContentPage>
